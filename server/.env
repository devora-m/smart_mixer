# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/smart_mixer

# SQLite
SQLITE_PATH=./smart_mixer.db

# HTTP
PORT=4000

# Session - REPLACE with a long random string for production!
SESSION_SECRET=change_this_to_a_long_random_string_in_production

# Edit password hash - generate with: npm run set-password
# (the API will reject all edits until you set this)
EDIT_PASSWORD_HASH=
